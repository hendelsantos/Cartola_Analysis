# ── Database ─────────────────────────────────────────────────────
# Railway provides DATABASE_URL automatically when you add a PostgreSQL plugin
# Locally: postgresql+asyncpg://postgres:postgres@localhost:5432/cartola_analytics
# Railway: postgresql://user:pass@host:port/dbname (auto-converted to asyncpg)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/cartola_analytics

# ── Redis (optional) ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Cartola API ──────────────────────────────────────────────────
CARTOLA_API_BASE_URL=https://api.cartola.globo.com

# ── App ──────────────────────────────────────────────────────────
APP_ENV=production
APP_DEBUG=false
APP_SECRET_KEY=change-me-in-production
APP_CORS_ORIGINS=["https://your-frontend.up.railway.app"]

# ── Sync ─────────────────────────────────────────────────────────
SYNC_INTERVAL_MINUTES=30

# ── Railway (set automatically by Railway) ───────────────────────
# RAILWAY_PUBLIC_DOMAIN=your-backend.up.railway.app
# RAILWAY_PRIVATE_DOMAIN=backend.railway.internal
